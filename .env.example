# Supabase Configuration
# Use the same Supabase project as bride's invitation
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Wedding Slug
# Groom's invitation: /undangan/indra-indah
# Bride's invitation: /undangan/demo (or your custom slug)
# Each invitation is a separate wedding record in the same database

# Optional: For production
# VITE_APP_URL=https://yourdomain.com
